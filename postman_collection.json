{
  "info": {
    "name": "Healthcare Backend API - WhatBytes Assignment",
    "description": "Complete collection for the Django Healthcare Backend assignment. Run requests top to bottom inside each folder -- Register, then Login (auto-saves the access token), then the resource folders. IDs returned by Create requests are auto-saved as collection variables for chaining.",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "variable": [
    { "key": "base_url", "value": "http://127.0.0.1:8000/api" },
    { "key": "access_token", "value": "" },
    { "key": "refresh_token", "value": "" },
    { "key": "patient_id", "value": "" },
    { "key": "doctor_id", "value": "" },
    { "key": "mapping_id", "value": "" }
  ],
  "auth": {
    "type": "bearer",
    "bearer": [{ "key": "token", "value": "{{access_token}}", "type": "string" }]
  },
  "item": [
    {
      "name": "Health",
      "item": [
        {
          "name": "Health Check",
          "request": {
            "auth": { "type": "noauth" },
            "method": "GET",
            "url": { "raw": "{{base_url}}/health/", "host": ["{{base_url}}"], "path": ["health", ""] }
          }
        }
      ]
    },
    {
      "name": "Auth",
      "item": [
        {
          "name": "Register",
          "request": {
            "auth": { "type": "noauth" },
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"name\": \"Dr. Jane Smith\",\n  \"email\": \"jane.smith@example.com\",\n  \"password\": \"SecurePass123\"\n}"
            },
            "url": { "raw": "{{base_url}}/auth/register/", "host": ["{{base_url}}"], "path": ["auth", "register", ""] }
          }
        },
        {
          "name": "Login",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "const json = pm.response.json();",
                  "if (json && json.data) {",
                  "    if (json.data.access) { pm.collectionVariables.set('access_token', json.data.access); }",
                  "    if (json.data.refresh) { pm.collectionVariables.set('refresh_token', json.data.refresh); }",
                  "}",
                  "pm.test('Login returned access token', function () {",
                  "    pm.expect(json.data.access).to.be.a('string');",
                  "});"
                ]
              }
            }
          ],
          "request": {
            "auth": { "type": "noauth" },
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"jane.smith@example.com\",\n  \"password\": \"SecurePass123\"\n}"
            },
            "url": { "raw": "{{base_url}}/auth/login/", "host": ["{{base_url}}"], "path": ["auth", "login", ""] }
          }
        }
      ]
    },
    {
      "name": "Patients",
      "item": [
        {
          "name": "Create Patient",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "const json = pm.response.json();",
                  "if (json && json.data && json.data.id) { pm.collectionVariables.set('patient_id', json.data.id); }"
                ]
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"name\": \"John Doe\",\n  \"age\": 34,\n  \"gender\": \"M\",\n  \"address\": \"221B Baker Street\",\n  \"phone_number\": \"+919876543210\",\n  \"medical_history\": \"No known allergies.\"\n}"
            },
            "url": { "raw": "{{base_url}}/patients/", "host": ["{{base_url}}"], "path": ["patients", ""] }
          }
        },
        {
          "name": "List Patients",
          "request": {
            "method": "GET",
            "url": { "raw": "{{base_url}}/patients/", "host": ["{{base_url}}"], "path": ["patients", ""] }
          }
        },
        {
          "name": "Get Patient Detail",
          "request": {
            "method": "GET",
            "url": {
              "raw": "{{base_url}}/patients/{{patient_id}}/",
              "host": ["{{base_url}}"],
              "path": ["patients", "{{patient_id}}", ""]
            }
          }
        },
        {
          "name": "Update Patient",
          "request": {
            "method": "PUT",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"name\": \"John Doe\",\n  \"age\": 35,\n  \"gender\": \"M\",\n  \"address\": \"221B Baker Street, London\",\n  \"phone_number\": \"+919876543210\",\n  \"medical_history\": \"No known allergies. Mild hypertension.\"\n}"
            },
            "url": {
              "raw": "{{base_url}}/patients/{{patient_id}}/",
              "host": ["{{base_url}}"],
              "path": ["patients", "{{patient_id}}", ""]
            }
          }
        },
        {
          "name": "Delete Patient",
          "request": {
            "method": "DELETE",
            "url": {
              "raw": "{{base_url}}/patients/{{patient_id}}/",
              "host": ["{{base_url}}"],
              "path": ["patients", "{{patient_id}}", ""]
            }
          }
        }
      ]
    },
    {
      "name": "Doctors",
      "item": [
        {
          "name": "Create Doctor",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "const json = pm.response.json();",
                  "if (json && json.data && json.data.id) { pm.collectionVariables.set('doctor_id', json.data.id); }"
                ]
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"name\": \"Dr. Aarav Mehta\",\n  \"specialization\": \"Cardiology\",\n  \"age\": 45,\n  \"gender\": \"M\",\n  \"email\": \"aarav.mehta@hospital.com\",\n  \"phone_number\": \"+919812345678\"\n}"
            },
            "url": { "raw": "{{base_url}}/doctors/", "host": ["{{base_url}}"], "path": ["doctors", ""] }
          }
        },
        {
          "name": "List Doctors",
          "request": {
            "method": "GET",
            "url": { "raw": "{{base_url}}/doctors/", "host": ["{{base_url}}"], "path": ["doctors", ""] }
          }
        },
        {
          "name": "Get Doctor Detail",
          "request": {
            "method": "GET",
            "url": {
              "raw": "{{base_url}}/doctors/{{doctor_id}}/",
              "host": ["{{base_url}}"],
              "path": ["doctors", "{{doctor_id}}", ""]
            }
          }
        },
        {
          "name": "Update Doctor",
          "request": {
            "method": "PUT",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"name\": \"Dr. Aarav Mehta\",\n  \"specialization\": \"Interventional Cardiology\",\n  \"age\": 46,\n  \"gender\": \"M\",\n  \"email\": \"aarav.mehta@hospital.com\",\n  \"phone_number\": \"+919812345678\"\n}"
            },
            "url": {
              "raw": "{{base_url}}/doctors/{{doctor_id}}/",
              "host": ["{{base_url}}"],
              "path": ["doctors", "{{doctor_id}}", ""]
            }
          }
        },
        {
          "name": "Delete Doctor",
          "request": {
            "method": "DELETE",
            "url": {
              "raw": "{{base_url}}/doctors/{{doctor_id}}/",
              "host": ["{{base_url}}"],
              "path": ["doctors", "{{doctor_id}}", ""]
            }
          }
        }
      ]
    },
    {
      "name": "Mappings",
      "item": [
        {
          "name": "Create Mapping (assign doctor to patient)",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "const json = pm.response.json();",
                  "if (json && json.data && json.data.id) { pm.collectionVariables.set('mapping_id', json.data.id); }"
                ]
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"patient\": {{patient_id}},\n  \"doctor\": {{doctor_id}}\n}"
            },
            "url": { "raw": "{{base_url}}/mappings/", "host": ["{{base_url}}"], "path": ["mappings", ""] }
          }
        },
        {
          "name": "List All Mappings",
          "request": {
            "method": "GET",
            "url": { "raw": "{{base_url}}/mappings/", "host": ["{{base_url}}"], "path": ["mappings", ""] }
          }
        },
        {
          "name": "Get Doctors For a Patient",
          "request": {
            "method": "GET",
            "url": {
              "raw": "{{base_url}}/mappings/{{patient_id}}/",
              "host": ["{{base_url}}"],
              "path": ["mappings", "{{patient_id}}", ""]
            }
          }
        },
        {
          "name": "Delete Mapping",
          "request": {
            "method": "DELETE",
            "url": {
              "raw": "{{base_url}}/mappings/{{mapping_id}}/",
              "host": ["{{base_url}}"],
              "path": ["mappings", "{{mapping_id}}", ""]
            }
          }
        }
      ]
    }
  ]
}
